# Application Configuration
APP_ENV=development
APP_HOST=http://localhost:3100
PORT=3100
BODY_LIMIT_MB=20

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=traveGo

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=24
AUTH_TOKEN_EXPIRY=90

# Email Configuration
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# OTP Configuration
OTP_LENGTH=6
OTP_TTL=300

# File Upload Paths
THUMBNAIL_FILE_PATH=assets/course/thumbnails/
COURSE_VIDEO_PATH=assets/course/videos/
COURSE_EBOOK_PATH=assets/course/ebooks/
AVATAR_PATH=assets/users/photos

# Midtrans Configuration
MIDTRANS_MERCHANT_ID=
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ENV=sandbox

# Frontend Base URL
APP_BASE_URL=http://localhost:5173

# ============================================
# WhatsApp AI Assistant (WAAI) Configuration
# ============================================

# Wagy WhatsApp Integration
WAGY_DEVICE_ID=OFFICE-01
WAGY_TOKEN=your-wagy-token-here
WAGY_WEBHOOK_SECRET=your-webhook-secret-here

# Anthropic API Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
